LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
CORS_ALLOW_ORIGINS=*
SECURITY_API_KEY=replace-with-strong-secret
DATABASE_URL=sqlite:///./aegismind.db
RATE_LIMIT_PER_WINDOW=60
RATE_LIMIT_WINDOW_SECONDS=60
LOGS_REQUIRE_DASHBOARD_AUTH=false
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=aegismind@localhost
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SECRETS_DIR=/run/secrets
AUTO_ARCHIVE_LOGS_DAYS=0
AUTO_ROTATE_API_KEYS_DAYS=0
AUTO_ROTATE_DEACTIVATE_OLD=true
AUTO_ROTATE_LABEL=auto-rotated
AUTO_ROTATE_EXPORT_PATH=
MAINTENANCE_INTERVAL_SECONDS=300
THREAT_FEED_URL=
THREAT_FEED_API_KEY=
THREAT_FEED_POLL_MINUTES=60
ENABLE_OPENTELEMETRY=false

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
CORS_ALLOW_ORIGINS=*
SECURITY_API_KEY=replace-with-strong-secret
DATABASE_URL=postgresql://aegisuser:aegispassword@db:5432/aegismind
LOGS_REQUIRE_DASHBOARD_AUTH=false
SECRETS_DIR=/run/secrets
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
AUTO_ARCHIVE_LOGS_DAYS=0
AUTO_ROTATE_API_KEYS_DAYS=0
